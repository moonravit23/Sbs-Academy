#include <stdio.h>

int main()
{
    //두 수를 입력받고 누가 더 큰지 알려주기

    int a = 0;
    int b = 0;
    
    printf("첫 수를 입력하세요 : ");
    scanf("%d", &a);
    
    printf("두번째 숫자를 입력하세요 : ");
    scanf("%d", &b);

    if (a > b)
        printf("첫번째 숫자가 더 큽니다.");
    else
        printf("두번째 숫자가 더 큽니다.");
}
